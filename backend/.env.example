# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
DATA_DIR=./data

# ─── Dashboard ────────────────────────────────────────────────────────────────
# CORS origin for the React dashboard
DASHBOARD_ORIGIN=http://localhost:5173

# ─── System-level Alerts ─────────────────────────────────────────────────────
# A dedicated "admin" bot token used only to send system-level alerts
# (optional — per-bot alerts use each bot's own token)
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=
